rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /patientCases/{caseId} {
      allow read, create, update: if signedIn();
      allow delete: if signedIn();
    }

    match /neuroRuns/{runId} {
      allow read, create, update: if signedIn();
      allow delete: if signedIn();
    }

    // TODO: Replace broad authenticated access with clinician role and case-assignment checks
    // before storing PHI or using Coherence in a production clinical workflow.
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // Helper: request comes from a signed-in user
    // -----------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    // -----------------------------------------------------------------------
    // patientCases — only the owning authenticated user may read or write
    // -----------------------------------------------------------------------
    match /patientCases/{caseId} {
      allow read, write: if isSignedIn();
    }

    // -----------------------------------------------------------------------
    // neuroRuns — signed-in users may read/write their own runs.
    // The Cloud Function (firebase-admin) bypasses these rules entirely, so
    // orchestration writes from the backend always succeed.
    // -----------------------------------------------------------------------
    match /neuroRuns/{runId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      // Allow update only if the caller owns the run (caseId match is a
      // reasonable proxy until per-user ownership is stored on the doc).
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // -----------------------------------------------------------------------
    // Deny everything else by default
    // -----------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
